# ===============================================================
#  NexusSwarm - Environment Configuration
#  Copy this to .env and fill in values locally.
#  Keep all values empty in this example file.
# ===============================================================

# App config
APP_ENV=
APP_SECRET_KEY=
LOG_LEVEL=
CORS_ALLOWED_ORIGINS=
CORS_ALLOWED_METHODS=
CORS_ALLOWED_HEADERS=
CORS_ALLOW_CREDENTIALS=
TRUSTED_HOSTS=
MAX_AGENT_RETRIES=
AGENT_TIMEOUT_SECONDS=
MAX_CONCURRENT_PIPELINES=

# LLM routing
LLM_PROVIDER=
NVIDIA_API_KEY=
NVIDIA_BASE_URL=
NIM_ORCHESTRATOR_MODEL=
NIM_MANAGER_MODEL=
NIM_WORKER_MODEL=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT_ORCHESTRATOR=
AZURE_OPENAI_DEPLOYMENT_MANAGER=
AZURE_OPENAI_API_VERSION=

# Infrastructure
REDIS_URL=
DATABASE_URL=
S3_BUCKET=
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Docker Compose local database settings
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# GitHub MCP
GITHUB_TOKEN=
GITHUB_REPO_OWNER=
GITHUB_DEFAULT_REPO=
